  <step>
    <name>Table input</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>conexao_banco_postgres_teste_etl_pessoas</connection>
    <sql>select
    p.id_staging,
    p.nome,
    p.cpf,
    p.data_nascimento,
    p.email,
    p.telefone,
    p.sexo,
    p.orgao,
    p.matricula,
    p.cargo,
    p.data_admissao,
    case
        when p.cpf in (
            select cpf
            from public.stg_pessoas
            where cpf is not null
              and trim(cpf) &lt;&gt; ''
            group by cpf
            having count(distinct nome) > 1
        ) then 'S'
        else null
    end as cpf_pessoas_diferentes,
    case
        when p.cpf in (
            select cpf
            from public.stg_pessoas
            where cpf is not null
              and trim(cpf) &lt;&gt; ''
            group by cpf
            having count(*) > 1
        ) then 'S'
        else null
    end as cpf_duplicado,
    case
        when p.matricula in (
            select matricula
            from public.stg_pessoas
            where matricula is not null
              and trim(matricula) &lt;&gt; ''
            group by matricula
            having count(*) > 1
        ) then 'S'
        else null
    end as matricula_duplicada
from public.stg_pessoas p
order by p.id_staging;</sql>
