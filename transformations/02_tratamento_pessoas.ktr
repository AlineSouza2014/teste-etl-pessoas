    <sql>select
    id_staging,
    nome,
    cpf,
    data_nascimento,
    email,
    telefone,
    sexo,
    orgao,
    matricula,
    cargo,
    data_admissao
from public.stg_pessoas
where status_processamento is null
order by id_staging;</sql>
