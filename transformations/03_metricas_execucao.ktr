    <connection>conexao_banco_postgres_teste_etl_pessoas</connection>
    <sql>with atual as (
    select max(id_execucao) as id_execucao_stage_atual
    from public.stg_pessoas
    where id_execucao is not null
),
ultima_metrica as (
    select max(id_execucao_stage) as ultimo_id_execucao_stage
    from public.etl_metricas_execucao
),
metricas_reais as (
    select
        max(id_execucao) as id_execucao_processo_real,
        max(id_execucao) as id_execucao_stage_real,
        count(*) as qtd_processados_execucao_real,
        coalesce(sum(case when status_processamento = 'PROCESSADO' then 1 else 0 end), 0) as qtd_validos_execucao_real,
        coalesce(sum(case when status_processamento = 'ERRO' then 1 else 0 end), 0) as qtd_invalidos_execucao_real
    from public.stg_pessoas
    where id_execucao = (
        select max(id_execucao)
        from public.stg_pessoas
        where id_execucao is not null
    )
)
select
    case
        when um.ultimo_id_execucao_stage = a.id_execucao_stage_atual then null
        else mr.id_execucao_processo_real
    end as id_execucao_processo,

    case
        when um.ultimo_id_execucao_stage = a.id_execucao_stage_atual then null
        else mr.id_execucao_stage_real
    end as id_execucao_stage,

    'TRATAMENTO_PESSOAS' as nome_processo,
    'SUCESSO' as status_execucao,
    cast(null as varchar(500)) as mensagem_erro,

    (
        select count(*)
        from public.stg_pessoas
        where status_processamento is null
    ) as qtd_pendentes,

    case
        when um.ultimo_id_execucao_stage = a.id_execucao_stage_atual then 0
        else mr.qtd_processados_execucao_real
    end as qtd_processados_execucao,

    case
        when um.ultimo_id_execucao_stage = a.id_execucao_stage_atual then 0
        else mr.qtd_validos_execucao_real
    end as qtd_validos_execucao,

    case
        when um.ultimo_id_execucao_stage = a.id_execucao_stage_atual then 0
        else mr.qtd_invalidos_execucao_real
    end as qtd_invalidos_execucao,

    (
        select count(*)
        from public.tb_pessoas
    ) as qtd_validos_total,

    (
        select count(*)
        from public.etl_pessoas_erros
    ) as qtd_invalidos_total

from atual a
cross join ultima_metrica um
cross join metricas_reais mr</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
