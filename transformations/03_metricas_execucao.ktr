        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>if (ultimo_id_execucao_stage == null || ultimo_id_execucao_stage != id_execucao_stage_atual) {
  qtd_processados_execucao = qtd_processados_execucao == null ? 0 : qtd_processados_execucao;
  qtd_validos_execucao = qtd_validos_execucao == null ? 0 : qtd_validos_execucao;
  qtd_invalidos_execucao = qtd_invalidos_execucao == null ? 0 : qtd_invalidos_execucao;
} else {
  qtd_processados_execucao = 0;
  qtd_validos_execucao = 0;
  qtd_invalidos_execucao = 0;
}</jsScript_script>
      </jsScript>
